		"@types/node": "^24",
		"@types/pg": "^8.20.0",
		"dotenv": "^17.4.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"prisma": "^7.8.0",
		"prisma-kysely": "^3.1.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
